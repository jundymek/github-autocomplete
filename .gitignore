# Dependencies
/node_modules
/.pnp
.pnp.*

# Testing
/coverage

# Production
/dist

# Misc
.DS_Store
*.pem

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment variables
.env
.env*.local

# Editor / IDE
.idea
.vscode/*
!.vscode/extensions.json

# TypeScript
*.tsbuildinfo

# Vercel
.vercel

# Playwright MCP — local browser-driven manual-testing artifacts (snapshots,
# screenshots, console logs), not app code.
.playwright-mcp/

# Playwright e2e — test artifacts, reports, and browser cache (binary lives
# in the OS-level Playwright cache, not in the repo).
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# BMAD method tooling and Claude Code skills — local build tooling, not app code.
# The process artifacts (PRD, architecture, epics, stories) live in docs/ instead.
/_bmad/
/.claude/

# Claude Design original exports (large, embedded fonts) — kept locally, not committed.
# The extracted clean templates in docs/design/*.html are the committed reference.
docs/design/bundles/

# Local agent handoff prompts — kept locally, not committed.
docs/_handoff/
